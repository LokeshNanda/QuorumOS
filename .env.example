# Database (PostgreSQL / Neon)
DATABASE_URL="postgresql://user:password@host:5432/quorumos?sslmode=require"

# Admin authentication (optional - if not set, admin routes are open for dev)
ADMIN_PASSWORD="your-secure-admin-password"
SESSION_SECRET="min-32-char-secret-for-signing-sessions"

# Cron (optional - for election scheduling, set to protect /api/cron/election-schedule)
CRON_SECRET="your-cron-secret"

# Upstash Redis (OTP + rate limiting)
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# Notification provider: resend | sendgrid | smtp
NOTIFICATION_PROVIDER="resend"

# Resend (when NOTIFICATION_PROVIDER=resend)
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="elections@societyvote.com"

# SendGrid (when NOTIFICATION_PROVIDER=sendgrid)
SENDGRID_API_KEY="SG.xxx"
SENDGRID_FROM_EMAIL="elections@societyvote.com"
